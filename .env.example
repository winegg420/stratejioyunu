# Supabase — "strateji oyunu" projesi → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Dashboard → Authentication → Providers → Google (Redirect URL: https://your-domain/giris)
# Authentication → URL Configuration → Site URL + Redirect URLs

# Kurucu / admin (virgülle çoklu isim veya e-posta)
# VITE_FOUNDER_PLAYER_NAME=Komutan_Alpha
# VITE_FOUNDER_EMAIL=you@example.com
# VITE_ADMIN_PLAYER_NAMES=

# Geliştirici solo-test: Sv.15 bina/araştırma, 100 birlik, savaş kilit bypass
# VITE_DEV_TEST_MODE=true
# Yerel depoda: localStorage.setItem('strateji_dev_test','1')

# Kurulum: .env.supabase.example → .env.supabase kopyala, doldur, sonra:
# npm run supabase:connect
